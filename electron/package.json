{
  "name": "signal-desktop",
  "version": "0.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "concurrently -k \"pnpm --dir ../ui dev\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "pnpm --dir ../ui build && electron-builder --config electron-builder.yml"
  },
  "dependencies": {
    "electron": "^36.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.4"
  }
}
